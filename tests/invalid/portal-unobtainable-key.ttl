# Caso rotto: la chiave del portale non è né drop né reward (viola sr:RequiredKeyMustExistInWorld).
@prefix sr:   <http://example.org/semantic-roguelike#> .
@prefix ex:   <http://example.org/id/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:testBiome a sr:Biome .

ex:roomA a sr:Room ;
  sr:isStartRoom true ;
  sr:locatedInBiome ex:testBiome ;
  sr:dangerLevel 1 ;
  sr:floorIndex 1 .

ex:roomB a sr:Room ;
  sr:locatedInBiome ex:testBiome ;
  sr:dangerLevel 1 ;
  sr:floorIndex 1 .

ex:ghostKey a sr:Item ;
  sr:rarity 5 .

ex:brokenPortal a sr:Portal ;
  sr:portalInRoom ex:roomA ;
  sr:requiresItem ex:ghostKey ;
  sr:unlocksRoom ex:roomB .
